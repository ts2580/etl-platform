<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.apache.sfdc.pubsub.repository.PubSubRepository">

    <select id="setTable" parameterType="String">
        ${DDL}
    </select>


    <!-- #은 Object를 받을 때. 문자열은 $로 처리-->
    <insert id="insertObject">
        ${upperQuery}
        <foreach item="record" collection="listUnderQuery" separator=",">
            ${record}
        </foreach>
        ${tailQuery}
    </insert>

    <update id="updateObject">
        ${strUpdate}
    </update>

    <delete id="deleteObject">
        ${strDelete}
    </delete>

    <select id="countActiveCdcSlots" resultType="int">
        SELECT COUNT(*)
        FROM cdc_slot_registry
        WHERE is_active = TRUE
    </select>

    <insert id="upsertActiveCdcSlot">
        INSERT INTO cdc_slot_registry (
            selected_object,
            is_active,
            created_at,
            updated_at
        ) VALUES (
            #{selectedObject},
            TRUE,
            NOW(),
            NOW()
        )
        ON DUPLICATE KEY UPDATE
            is_active = TRUE,
            updated_at = NOW()
    </insert>

</mapper>

